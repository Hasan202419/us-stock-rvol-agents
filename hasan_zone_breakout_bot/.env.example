# Hasan Zone Breakout VWAP Scalping Signal Bot — .env namunasi
# Bu faylni nusxalang: copy .env.example .env  (Windows)  yoki  cp .env.example .env
# Keyin o'z kalitlaringizni qo'ying. Maxfiy kalitlarni hech kimga bermang.

# ----- Telegram (alert yuborish uchun) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Alpaca (1-manba: realtime quote + bid/ask) -----
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ----- IBKR.com hosted Web API (Gateway/noutbuk SHART EMAS) -----
# Yoqish uchun true qiling va Client Portal Web API URL'ini bering
IBKR_WEB_API_ENABLED=false
IBKR_WEB_API_BASE_URL=
IBKR_WEB_API_TOKEN=
IBKR_WEB_API_VERIFY_SSL=true

# ----- IBKR ib_insync Gateway (ilg'or, kompyuterda ochiq turishi kerak) -----
IBKR_ENABLED=false
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4002
IBKR_CLIENT_ID=9

# ----- Bot sozlamalari -----
REFRESH_SECONDS=60
# SCAN_MODE: large_cap | penny | both
SCAN_MODE=both

# Penny watchlist (vergul bilan) — bo'sh bo'lsa standart ro'yxat
PENNY_WATCHLIST=

# Dedup (bir xil tic'kerni necha daqiqada qayta yubormaslik)
DEDUP_MINUTES=10
