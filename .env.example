# --- MASTER_PLAN (jarvis layer: src/) ---
# DATABASE_URL=sqlite:///jarvis.db
# ZOYA_API_KEY=
# FMP_API_KEY=
# NEWSAPI_KEY=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# CAPITAL=10000
# MAX_RISK_PCT=1.0
# MAX_DAILY_LOSS_PCT=2.0
# HALAL_MAX_DEBT_RATIO=0.30
# HALAL_MAX_IMPURE_REV=0.05
# HALAL_MAX_CASH_RATIO=0.30
# Alias: ALPACA_KEY_ID bor bo‘lsa, `ALPACA_API_KEY` o‘rniga ishlatiladi (src/config/settings).
# `load_project_env`: MASTER_PLAN `# KEY=value` aktiv qator bo‘sh bo‘lsa os.environ ga chiqariladi (Finviz Elite AUTH/QUERY ham).
# =====================================================================
# API kalitlari: har bir kalit NOMI uchun faqat BITTA faol qator (OPENAI_API_KEY=...).
# Pastga takrorlangan OPENAI_API_KEY= yoki bo‘sh qator Qo‘yma — oxirgi yozuv ustun; bo‘sh bo‘lsa
# yuqoridagi to‘liq kalit "o‘chgan"dek ko‘rinadi (`check_apis` da ham `! .env takrori`).
# Fayl yo‘li: faqat …\us-stock-rvol-agents\.env — C:\Users\…\.env (uy papkasi) aralashtirmang.
# restore_env_from_comments.py — faqat kerak bo‘lganda ishga tushiring; yozish-o‘zgartirish uchun emas.
# =====================================================================

# Tiklash (--dry-run): scripts/restore_env_from_comments.py

# --- Render: deploy (python scripts/trigger_render_deploy.py · .\scripts\deploy_render.ps1) ---
#
# VARIANT A — Deploy Hook (POST URL; API kalit kerak emas):
#   RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-....?key=...   (Dashboard → Service → Build & Deploy → Deploy Hook)
#   RENDER_WORKER_DEPLOY_HOOK_URL=...   # ixtiyoriy — Telegram worker uchun alohida hook
#
# VARIANT B — Render REST API (Deploy Hook bo‘lmasa):
#   RENDER_API_KEY=rnd_...                 (Dashboard → Account Settings → API Keys)
#   RENDER_OWNER_ID=tea-...                # Workspace / Team ID (`ensure_render_telegram_worker.py`; bo‘sh bo‘lsa API /v1/owners orqali aniqlanadi)
#   RENDER_SERVICE_ID=srv-...              # Web service (masalan us-stock-rvol-dashboard)
#   RENDER_WORKER_SERVICE_ID=srv-...       # ixtiyoriy — ikkinchi servis (Telegram bot worker)
#
# Qo‘shimcha: RENDER_SERVICE_NAME=us-stock-rvol-dashboard — ID bo‘sh bo‘lsa nom bo‘yicha topish (bootstrap_env).
# SKIP_RENDER_SERVICE_RESOLVE=true        # avto-ID ni o‘chirish
# Servislar ro‘yxati: python scripts/list_render_services.py
# Worker holati + Telegram: python scripts/render_worker_smoke.py
# Git push + deploy (Windows): scripts/push_and_deploy_windows.ps1
#
RENDER_API_KEY=
# RENDER_OWNER_ID=tea-xxxxxxxx    # Workspace ID — worker yaratish uchun (Dashboard → Team → Settings)
RENDER_SERVICE_ID=
# RENDER_SERVICE_NAME=us-stock-rvol-dashboard
# RENDER_WORKER_SERVICE_ID=
# RENDER_DEPLOY_HOOK_URL=
# RENDER_WORKER_DEPLOY_HOOK_URL=

# --- GitHub: PAT — bu yerga token (faqat lokal .env; repoga commit qilmang) ---
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Supabase (keyinroq: Postgres/Auth — loyiha sozlamalaridan URL va kalitlar) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # faqat server; client kodga qo‘ymang

OPENAI_API_KEY=
# Sukut AI_PROVIDER=auto: ikkala kalit (OPENAI va DEEPSEEK) bo‘lsa runtime DeepSeek ustun (ixtiyoriy fallback OpenAI uchun).
# Faqat DeepSeek: AI_PROVIDER=deepseek (kalit yoʻq boʻlsa OPENAI qoʻshilsa fallback). Faqat OpenAI: AI_PROVIDER=openai.
AI_PROVIDER=auto
# Skan paytida LLM chaqiruvlari: 429/5xx uchun eksponensial qayta urinish.
# OPENAI_ANALYSIS_MAX_RETRIES=4
# OPENAI_ANALYSIS_RETRY_BASE_SEC=1.25
# DeepSeek (OpenAI-compatible ulanish API). Izohlangan ketma-kilik: `.env.example` va `agents/chatgpt_analyst_agent`.
# Qiymatlar: auto | openai | deepseek
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

POLYGON_API_KEY=
# Alpha Vantage (ixtiyoriy — Polygon/Yahoo yo‘q kunlik shamalar uchun). Bepul rejada so‘rov cheklovi kichik.
# ALPHA_VANTAGE_API_KEY=
# ALPHA_VANTAGE_ENABLED=true
FINNHUB_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
TRADING_MODE=paper
DATA_DELAY_MINUTES=15

# STRATEGY_MODE=rvol | vwap_breakout | mtrade_high_volatility | volume_ignition
# volume_ignition — alohida bullish skan (kunlik hajm/EMA/qarshilik); mtrade_high_volatility — VWAP+Pine intraday rejimi.
STRATEGY_MODE=rvol
INTRADAY_TIMEFRAME_MINUTES=5
INTRADAY_LOOKBACK_DAYS=7
SESSION_OPEN_PLUS_MINUTES=3
SESSION_CLOSE_MINUS_MINUTES=27
VWAP_R_MULTIPLIER=3
# MTRADE_R_MULTIPLIER=3
# Pine: bar ochilish (time) bilan sessiya oynasi; bar_end eski usul.
# VWAP_SESSION_WINDOW=bar_open
# VWAP_REGULAR_ANCHOR=bar_open
# VWAP_PINE_STATE_MACHINE=true
# VWAP_USE_CLOSE_FOR_EXITS=true
# RESTRICT_VWAP_TIMEFRAMES=true
# SYMBOL_MINTICK=0.01
# VWAP_STRATEGY_NAME=
ALPACA_DATA_FEED=iex

# Finviz Elite — CSV eksport → universe (dashboard yoki FETCH_UNIVERSE_FINVIZ_FIRST)
# FINVIZ_ELITE_AUTH=                    # Elite eksport URL dagi uuid (repoga commit qilinmasin)
# FINVIZ_ELITE_EXPORT_QUERY=          # "? dan keyingi" parametrlar (v=...&f=...); auth yozmang
# FINVIZ_ELITE_EXPORT_BASE=https://elite.finviz.com/export
# FETCH_UNIVERSE_FINVIZ_FIRST=false   # true bo'lsa Finviz birinchi sinab ko'riladi (.env)

# Yahoo Finance (via yfinance) — no API key; fills gaps after other providers / intraday fallback.
YAHOO_FINANCE_ENABLED=true
# Intraday: Alpaca bo‘sh bo‘lsa, Yahoo ni Polygon dan oldin sinash (Polygon limiti yoki tezlik uchun).
# INTRADAY_YAHOO_BEFORE_POLYGON=false

# IGNITION_MIN_AVG_VOLUME=1000000
# IGNITION_MIN_RVOL=2
# IGNITION_VOL_VS_20D_AVG=2
# IGNITION_MAX_3DAY_GAIN_PCT=10
# IGNITION_MAX_RES_DISTANCE_PCT=5
# IGNITION_RESISTANCE_LOOKBACK=20
# IGNITION_EXTENDED_MOVE_BAN_PCT=20
# IGNITION_EXTENDED_LOOKBACK=20
# IGNITION_PARABOLIC_RANGE_PCT=15
# IGNITION_PARABOLIC_2DAY_JUMP_PCT=8
# IGNITION_EMA_EXTENSION_MAX_PCT=8

MIN_RVOL=1.35
MIN_PRICE=1
MIN_VOLUME=200000
# Allow mild red days for exploration; set to 0.05 for “must be green”.
MIN_CHANGE_PERCENT=-2
# Ixtiyoriy: MASTER-spec yaqin RSI zonasi faqat RVOL rejimida (kunlik RSI hisoblangan bo‘lsa).
# DAILY_RSI_GATE_ENABLED=false
# DAILY_RSI_MIN=55
# DAILY_RSI_MAX=70
# DAILY_RSI_PASS_IF_MISSING=true
# Parallel workers for dashboard scans (Streamlit slider can override live).
SCAN_MAX_WORKERS=10
# Agar qattiq rejimda 0 signal chiqsa, avtomatik RVOL yumshoq fallback urinish (bo'sh natijani kamaytiradi).
# SCAN_RELAX_ON_EMPTY=true
MAX_POSITION_SIZE_USD=10000
MAX_DAILY_LOSS_USD=50
MAX_TRADES_PER_DAY=5

# Risk sizing (paper): % of equity for risk budget; min reward:risk for bracket TP.
# ACCOUNT_EQUITY_USD=10000
MAX_RISK_PCT_OF_EQUITY=1.0
MIN_RISK_REWARD_RATIO=2.0
# STRICT_AI_HARD_GATES=true

# Intraday HTTP retry + short cache; optional regular-session bar filter.
MARKET_HTTP_MAX_RETRIES=4
MARKET_HTTP_BACKOFF_BASE_SEC=0.75
INTRADAY_CACHE_TTL_SECONDS=45
# FILTER_INTRADAY_REGULAR_SESSION=false

# Execution: bracket (TP+SL) or legacy oto.
ALPACA_ORDER_STYLE=bracket
ALPACA_ORDER_ID_PREFIX=hasan

# Kill switch file (auto path: state/kill_switch.json under PROJECT_ROOT).
# KILL_SWITCH_PATH=

# Telegram: @BotFather token va chat ID (username yoki -100...). MASTER_PLAN izohidan ham yuklanishi mumkin.
#
# Ikki sahna uchun bir xil .env qo‘llanadi — Render’da WEB (dashboard) + WORKER (`telegram_command_bot`): ikkalasiga bir xil
# OPENAI_* / market API / TELEGRAM_* nusxlash (faqat BOT_TOKEN boshqa bo‘lsa alohida service).
#
# One-way alertlar (`TelegramAlertsAgent`) uchun TELEGRAM_CHAT_ID kerak; command bot replylari chat_id ni incoming xabardan oladi.
# TELEGRAM_CHAT_ID — o‘ZINGIZ telegram user/chat raqami; TOKEN=72345:AA… dagi boshidagi 72345 bot-ID (xato yozmaslik).
# Minimal “scan yakunidan keyin Telegram alert”:
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
TELEGRAM_ALERT_ON_SCAN=true
TELEGRAM_ALERT_TOP_N=5
# Umumiy eslatmalar uchun alohida (TELEGRAM_ALERT_ON_SCAN bo‘lsa alerts_enabled shart emas).
# TELEGRAM_ALERTS_ENABLED=false

# ---
# Eskiz: Dashboard faqat — TELEGRAM_ALERT_ON_SCAN=false  (faqat Telegram workerda kerak deganda).
# Eskiz: Faqat boshqa LLM — AI_PROVIDER=deepseek va OPENAI_API_KEY ni bo‘sh qoldiring (yoki teskari).

# Telegram command bot (polling): python scripts/telegram_command_bot.py — bir xil TOKEN.
# /scan command o‘zi reply beradi; duplicate alert bo‘lmasligi uchun workerda TELEGRAM_ALERT_ON_SCAN=false tavsiya qilinadi.
# Ixtiyoriy whitelist (vergul bilan chat id lar); productionda qo‘yish tavsiya qilinadi.
# TELEGRAM_ALLOWED_CHAT_IDS=                  # masalan: 123,-1001234567890 (guruh ID manfiy bo‘lishi mumkin)
# Bot javobidagi “Top” qatorlar (1…500, sukut 6). render.yaml / ensure_render sinxronlamaydi — faqat kerak bo‘lsa lokal .env yoki Render dashboardda.
# TELEGRAM_BOT_REPLY_TOP_N=6
# state/last_telegram_scan.json (1…500, sukut 6).
# TELEGRAM_BOT_TOP_ROWS=6
# Skan/signals xabarining oxirida yig‘iladigan qo‘llanmalar (analyst + ignition + HASAN). O‘chirish: false
# TELEGRAM_APPEND_FRAMEWORKS=true
# LLM system promptiga qisqa framework qo‘shish (ChatGPT/DeepSeek). O‘chirish: false
# LLM_ANALYST_FRAMEWORK_APPEND=true
# Telegram `/` menyusi (setMyCommands) — bot restartda yangilanadi. O‘chirish: true
# TELEGRAM_SKIP_SET_MY_COMMANDS=false
# Babir uslubi: worker yonida fon rejimda skan + xabar (kunlik yoki interval).
# TELEGRAM_AUTO_PUSH_ENABLED=true
# TELEGRAM_AUTO_PUSH_INTERVAL_MINUTES=1440   # ~24 soatda bir marta (worker vaqtida)
# TELEGRAM_AUTO_PUSH_FIRST_DELAY_SEC=120      # ishga tushgandan keyin birinchi pushgacha kutish
# TELEGRAM_AUTO_PUSH_CHAT_ID=                 # bo‘sh bo‘lsa TELEGRAM_CHAT_ID yoki allowlistda bitta chat
# TELEGRAM_AUTO_PUSH_USE_SCANALL=false        # true bo‘lsa har pushda /scanall qamrovi
# NY savdo kunlari (dush–juma ET) uchun lokal soatda avtomatik skan (masalan O‘zbekiston ~18:30 = NY ochilishiga yaqin)
# TELEGRAM_AUTO_PUSH_AT=18:30
# TELEGRAM_AUTO_PUSH_TZ=Asia/Tashkent
# Babir uslubi (sukut): pass bo‘lmasa ham kuzatuv ro‘yxati (~6–10 ticker) Telegramga chiqadi
# TELEGRAM_AUTO_PUSH_PASS_ONLY=false
# TELEGRAM_AUTO_PUSH_BABIR_WATCHLIST=true
# true = faqat haqiqiy pass (kuzatuv yuborilmaydi)
# TELEGRAM_AUTO_PUSH_PASS_ONLY=true
# /scan uchun dashboard presetlari (Explorer | Balanced | Conservative).
# Long-polling Telegram worker: `SCAN_AI_INCLUDE_FAILS=true` — Strategiya pass bo‘lmagan aksiyalar uchun ham DeepSeek/OpenAI javobi (LLM chaqiruqlar ko‘payadi).
# SCAN_AI_INCLUDE_FAILS=true
# LLM JSON ichida trade_plan (6 bo‘lim); false bo‘lsa faqat deterministik reja.
# ANALYST_TRADE_PLAN_ENABLED=true
# ANALYST_TRADE_PLAN_LANG=en
# Volume ignition (STRATEGY_MODE=volume_ignition):
# IGNITION_MIN_AVG_VOLUME=1000000
# IGNITION_MIN_RVOL=2
# IGNITION_VOL_VS_20D_AVG=2
# IGNITION_MAX_3DAY_GAIN_PCT=10
# IGNITION_MAX_RES_DISTANCE_PCT=5
# IGNITION_RESISTANCE_LOOKBACK=20
# IGNITION_EXTENDED_MOVE_BAN_PCT=20
# IGNITION_EXTENDED_LOOKBACK=20
# IGNITION_PARABOLIC_RANGE_PCT=15
# IGNITION_PARABOLIC_2DAY_JUMP_PCT=8
# IGNITION_EMA_EXTENSION_MAX_PCT=8
# --- MTF (1m/5m/10m/1H) — prop qisqa muddat: har TF da oxirgi yopilish va EMA9 taqqoslash (intraday barlar) ---
# MTF_SNAPSHOT_ENABLED=true
# MTF_SNAPSHOT_STRATEGY_PASS_ONLY=true   # false: strategiya o‘tmagan tickerlar ham (API yuki oshadi)
# MTF_TIMEFRAMES=1,5,10,60                # vergul bilan; off | false — o‘chirish
# MTF_LOOKBACK_CALENDAR_DAYS=7           # bo‘sh bo‘lsa INTRADAY_LOOKBACK_DAYS ishlatiladi
# --- AMT scalping (Pine: VAL/VWAP zona + EMA9) — intraday TF bo‘yicha BUY/TP kuzatuv ---
# Skalp / day trade: har signalda KIRISH · SL · CHIQISH1/2 (Telegram + /plan)
# SCALP_DAYTRADE_LEVELS_ENABLED=true
# SCALP_LEVELS_PREFER_AMT=true          # AMT (VAL/POC/VAH) ustun; yo‘q bo‘lsa strategiya SL/TP
# SCALP_FILL_MISSING_SL_TP=true         # stop_suggestion / take_profit bo‘sh bo‘lsa to‘ldirish
# AMT_VWAP_SCALP_ENABLED=true
# AMT_RANK_BUY_FIRST=true                # BUY signali bo‘lganlarni ro‘yxat boshiga
# AMT_SNAPSHOT_PASS_ONLY=false           # true: faqat strategy_pass bo‘lganlar (API tejaydi)
# AMT_TIMEFRAME_MINUTES=5                # bo‘sh: INTRADAY_TIMEFRAME_MINUTES
# AMT_SESSION_LEN=20
# AMT_EMA_LEN=9
# AMT_LOOKBACK_CALENDAR_DAYS=7
# TELEGRAM_SCAN_PRESET=Explorer
# TELEGRAM_FORCE_EXPLORER=true
# TELEGRAM_MAX_SYMBOLS=0
# 0 = cheklovsiz (Alpaca/Polygon qaytargan barcha US tradable). Son bo‘lsa 1..9999999 gacha.
# TELEGRAM_MAX_SYMBOLS_ALL=0
# /scanall: 0 = cheklovsiz; yoki aniq son (masalan 3000).
# TELEGRAM_AUTO_PUSH_USE_SCANALL=true   # kunlik avto-pushda /scanall qamrovi (cheklovsiz uzoq va API limit)
# TELEGRAM_DESK_LABEL=TG scan
# TELEGRAM_USE_FINVIZ_CSV=false
# Backtest MVP (yahoo kunlik):
# TELEGRAM_BACKTEST_TICKER=SPY
# TELEGRAM_BACKTEST_LOOKBACK_DAYS=400
# TELEGRAM_BACKTEST_FAST_SMA=10
# TELEGRAM_BACKTEST_SLOW_SMA=30

# --- Email (SMTP) — Telegram bilan bir xil vaqtda yoki alohida; kalitlar shu `.env` da ---
# Gmail: App Password + EMAIL_FROM=maning@gmail.com. Ko‘p qabul qiluvchi: EMAIL_TO=a@x.com,b@y.com
# EMAIL_ALERTS_ENABLED=false
# EMAIL_ALERT_ON_SCAN=false   # true bo‘lsa skan oxirida xat yuboriladi (EMAIL_ALERTS_ENABLED shart emas)
# EMAIL_ALERT_TOP_N=3         # bo‘sh bo‘lsa TELEGRAM_ALERT_TOP_N ishlatiladi
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_SSL=false          # true + port 465: SMTP_SSL
# SMTP_TLS_VERIFY=true        # false — faqat ichki/debug relay
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
# EMAIL_TO=

# FMP / NewsAPI / Zoya (ixtiyoriy; halal gate va yangiliklar uchun).
# FMP_API_KEY=
# NEWSAPI_KEY=
# ZOYA_ENABLED=true              # false — Zoya chaqiruvlari va check_apis da Zoya tekshiruvi o‘chadi (kalit ishlamasa shuni ishlating).
# ZOYA_API_KEY=

# --- Prop firma (faqat raqamli qoidalar / UI — alohida API kaliti YO‘Q) ---
# Barcha API lar (OpenAI, Alpaca, Polygon, Finviz, Telegram, …) faqat yuqoridagi umumiy
# `OPENAI_API_KEY=`, `ALPACA_*=`, `POLYGON_API_KEY=` va hokazo satrlarda. Prop yoki boshqa
# kichik loyiha alohida papkada bo‘lsa ham: shu nomdagi kalitlarni BIR xil `.env` da
# ushlang (nusxa yoki Windows symbolic link: bitta manba), `PROP_*API*` kabi alohida nomlar kerak emas.
# PROP_FIRM_NAME=Toro250
# PROP_PLAN_ADVANCED_USD=299
# PROP_BUYING_POWER_USD=250000
# PROP_PROFIT_TARGET_USD=15000
# PROP_PROFIT_TARGET_PCT=6
# PROP_DAILY_MAX_LOSS_USD=1250
# PROP_MAX_DRAWDOWN_USD=7500
# PROP_MAX_DRAWDOWN_PCT=3
# PROP_CONSISTENCY_MIN_PCT=50
# PROP_MIN_ROUND_TRADES=200
